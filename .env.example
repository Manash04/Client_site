# Himtatwa - Environment Variables
# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git

# Supabase (get from https://supabase.com/dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Razorpay (get from https://dashboard.razorpay.com > Settings > API Keys)
# Use rzp_live_... keys for production
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Resend (get from https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=himtatwa@gmail.com

# WhatsApp (country code + number, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=918218209756

# App URL (your production domain)
NEXT_PUBLIC_APP_URL=https://himtatwa.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
